  "keywords": [
    "agent-skill",
    "website-clone",
    "visual-regression",
    "playwright",
    "cdp",
    "motion-testing"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "playwright": "^1.54.0"
  },
  "files": [
    "SKILL.md",
    "agents/",
    "scripts/",
    "README.md",
    "LICENSE"
  ]
}
